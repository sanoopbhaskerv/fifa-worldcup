# Server-only secrets. Never prefix these with VITE_.
FOOTBALL_DATA_API_KEY=
API_FOOTBALL_API_KEY=

# Temporary static-production live mode. These are embedded in browser assets.
# Use only if you accept that users can extract the provider keys from dist/.
VITE_FOOTBALL_DATA_API_KEY=
VITE_API_FOOTBALL_API_KEY=

# Optional provider and server overrides.
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_DAILY_BUDGET=90
VITE_FOOTBALL_DATA_BASE_URL=/football-data/v4
VITE_API_FOOTBALL_BASE_URL=/api-football
VITE_API_FOOTBALL_DAILY_BUDGET=90
PORT=4173
